# NAME: Global DNS Providers
# 作用：确保加密 DNS 解析请求走代理，防止 DNS 污染

# Google DNS
DOMAIN-SUFFIX,dns.google

# Cloudflare DNS
DOMAIN-SUFFIX,cloudflare-dns.com
DOMAIN,1dot1dot1dot1.cloudflare-dns.com

# DNS.sb (非常纯净的第三方 DNS)
DOMAIN-SUFFIX,dns.sb
DOMAIN-SUFFIX,dot.sb

# OpenDNS / Cisco Umbrella
DOMAIN-SUFFIX,opendns.com
DOMAIN-SUFFIX,umbrella.com

# Quad9 DNS
DOMAIN-SUFFIX,quad9.net
